APP_NAME=StorageApp
ENV=dev
DEBUG=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/storageapp
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=1440
OAUTH_ENABLED=false

STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://127.0.0.1:8000

S3_BUCKET=storageapp-media
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

FREE_QUOTA_GB=15
PREMIUM_QUOTA_GB=25
SHARE_TOKEN_TTL_HOURS=168

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=StorageApp
